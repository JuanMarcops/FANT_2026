<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8">
<style>
  @page {
    size: A4;
    margin: 22mm 20mm 20mm;
    @bottom-center { content: counter(page); font: 9pt Georgia, serif; color: #888; }
    @top-right { content: "{{ conf.title }}"; font: 8pt Georgia, serif; color: #aaa; }
  }
  @page :first { @top-right { content: ""; } @bottom-center { content: ""; } }

  body { font: 11pt/1.55 Georgia, "Times New Roman", serif; color: #1A1714; background: #fff; }

  /* ── Title page ── */
  .titlepage { text-align: center; page-break-after: always; padding-top: 24%; }
  .titlepage img { height: 60pt; margin-bottom: 1.5rem; display: block; margin-left: auto; margin-right: auto; }
  .titlepage h1 { font-size: 22pt; margin: 0 0 .4rem; }
  .titlepage .subtitle { font-size: 13pt; color: #6B5F52; margin: 0 0 1.2rem; }
  .titlepage .meta { font-size: 10.5pt; color: #6B5F52; }
  .triband { width: 55mm; height: 4pt; margin: 2rem auto 0;
    background: linear-gradient(90deg, #BB4B27 0 33.34%, #C88A2A 33.34% 66.67%, #2B5740 66.67% 100%); }

  /* ── Intro ── */
  .intro { page-break-after: always; font-size: 10.5pt; line-height: 1.6; }
  .intro p:first-child { margin-top: 0; }

  /* ── TOC ── */
  .toc { page-break-after: always; }
  .toc h2 { font-size: 13pt; border-bottom: 1pt solid #1A1714; padding-bottom: .2rem; margin-bottom: .8rem; }
  .toc-section { margin-bottom: .9rem; }
  .toc-track { font-weight: bold; font-size: 10.5pt; color: #2B5740; margin: 0 0 .2rem; }
  .toc-entries { list-style: none; margin: 0 0 0 .5rem; padding: 0 0 0 .6rem; border-left: 1.5pt solid #DDD5C8; }
  .toc-entries li { margin-bottom: .35rem; line-height: 1.3; }
  .toc-entry-title { font-size: 9.5pt; }
  .toc-byline { display: block; font-size: 8.5pt; font-style: italic; color: #6B5F52; }
  .toc-coauthors { color: #1A1714; }

  /* ── Sessions ── */
  section.session { page-break-inside: auto; }
  section.session > h2 {
    font-size: 12pt; color: #2B5740;
    border-bottom: 1pt solid #DDD5C8;
    padding-bottom: .2rem; margin: 1.4rem 0 1rem;
    page-break-after: avoid;
  }

  /* ── Entry ── */
  article.entry { margin-bottom: 1rem; padding-left: .7rem; border-left: 2.5pt solid #C88A2A; page-break-inside: avoid; }
  article.entry h3 { font-size: 11pt; margin: 0 0 .2rem; page-break-after: avoid; }

  /* ── Byline ── */
  .byline { margin-bottom: .35rem; }
  p.presenter { font-style: italic; margin: 0 0 .05rem; font-size: 10.5pt; }
  p.presenter .institution { font-style: normal; font-size: 9pt; color: #BB4B27; }
  p.presenter .institution::before { content: " · "; color: #DDD5C8; }
  p.coauthors { font-style: italic; font-size: 10pt; color: #1A1714; margin: 0; padding-left: .5rem; border-left: 1.5pt solid #DDD5C8; }

  p.abstract { margin: 0 0 .3rem; text-align: justify; }
  p.keywords { font-size: 8.5pt; color: #6B5F52; margin: 0; }
</style>
</head>
<body>
  <div class="titlepage">
    {% if has_logo %}<img src="logo.png" alt="{{ conf.title }}">{% endif %}
    <h1>{{ conf.title }}</h1>
    <p class="subtitle">{{ conf.subtitle }}</p>
    <p class="meta">{{ conf.dates }}<br>{{ conf.location }}<br><br>{{ total }} {{ t.contributions }}</p>
    <div class="triband"></div>
  </div>

  {% if intro %}
  <div class="intro">{{ intro | safe }}</div>
  {% endif %}

  <div class="toc">
    <h2>{{ t.contents }}</h2>
    {% for block in sessions %}
    <div class="toc-section">
      <p class="toc-track">{{ t.tracks.get(block.track, block.track) }} ({{ block.entries|length }})</p>
      <ol class="toc-entries">
        {% for e in block.entries %}
        <li>
          <span class="toc-entry-title">{{ e.title }}</span>
          <span class="toc-byline">
            {{ e.authors }}{% if e.co_authors %} · <span class="toc-coauthors">{{ e.co_authors | join(" · ") }}</span>{% endif %}
          </span>
        </li>
        {% endfor %}
      </ol>
    </div>
    {% endfor %}
  </div>

  {% for block in sessions %}
  <section class="session">
    <h2>{{ t.tracks.get(block.track, block.track) }}</h2>
    {% for e in block.entries %}
    <article class="entry">
      <h3>{{ e.title }}</h3>
      <div class="byline">
        {% if e.authors %}
        <p class="presenter">
          {{ e.authors }}{% if e.institution %}<span class="institution">{{ e.institution }}</span>{% endif %}
        </p>
        {% endif %}
        {% if e.co_authors %}
        <p class="coauthors">{{ e.co_authors | join(" · ") }}</p>
        {% endif %}
      </div>
      {% if e.abstract %}<p class="abstract">{{ e.abstract }}</p>{% endif %}
      {% if e.keywords %}<p class="keywords">{{ e.keywords }}</p>{% endif %}
    </article>
    {% endfor %}
  </section>
  {% endfor %}
</body>
</html>
