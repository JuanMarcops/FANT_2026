<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ conf.title }} – {{ conf.subtitle }}</title>
<style>
  :root {
    --ink:    #1A1714;
    --muted:  #6B5F52;
    --rule:   #DDD5C8;
    --terra:  #BB4B27;
    --ochre:  #C88A2A;
    --forest: #2B5740;
    --bg:     #F9F5EF;
    --measure: 46rem;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font: 16px/1.6 Georgia, "Times New Roman", serif;
  }
  .wrap { max-width: var(--measure); margin: 0 auto; padding: 2.5rem 1.25rem 4rem; }

  /* ── Header ── */
  header { padding-bottom: .6rem; margin-bottom: 1.8rem; }
  .header-top {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
    margin-bottom: .6rem;
  }
  .logo { height: 4rem; width: auto; flex-shrink: 0; }
  .header-text { flex: 1; }
  header h1 { font-size: 1.75rem; line-height: 1.2; margin: 0 0 .25rem; }
  header .subtitle { font-size: 1rem; color: var(--muted); margin: 0 0 .4rem; }
  header .meta { font-size: .85rem; color: var(--muted); margin: 0; }
  header .meta a { color: var(--terra); text-decoration: none; }
  header .meta a:hover { text-decoration: underline; }
  .triband {
    height: 4px;
    margin-top: .9rem;
    background: linear-gradient(
      90deg,
      var(--terra)  0 33.34%,
      var(--ochre)  33.34% 66.67%,
      var(--forest) 66.67% 100%
    );
  }

  /* ── Intro block ── */
  .intro {
    margin-bottom: 2rem;
    padding: 1.2rem 1.4rem;
    background: #fff;
    border-left: 4px solid var(--ochre);
    font-size: .95rem;
    line-height: 1.65;
  }
  .intro p:first-child { margin-top: 0; }
  .intro p:last-child  { margin-bottom: 0; }

  /* ── TOC ── */
  nav.toc {
    margin: 0 0 2.5rem;
    font-family: -apple-system, system-ui, sans-serif;
    font-size: .875rem;
  }
  nav.toc strong {
    display: block;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: .72rem;
    color: var(--muted);
    margin-bottom: .4rem;
  }
  nav.toc ol { margin: 0; padding-left: 1.2rem; }
  nav.toc li { margin-bottom: .15rem; }
  nav.toc a { color: var(--ink); text-decoration: none; }
  nav.toc a:hover { color: var(--terra); }

  /* ── Sessions ── */
  section.session { margin-bottom: 2.8rem; }
  section.session > h2 {
    font-family: -apple-system, system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--forest);
    letter-spacing: .01em;
    margin: 0 0 1.2rem;
    padding-bottom: .3rem;
    border-bottom: 1px solid var(--rule);
  }
  section.session > h2::before {
    content: "";
    display: block;
    height: 3px;
    width: 2.2rem;
    margin-bottom: .5rem;
    background: linear-gradient(
      90deg,
      var(--terra)  0 33.34%,
      var(--ochre)  33.34% 66.67%,
      var(--forest) 66.67% 100%
    );
  }

  /* ── Entry ── */
  article.entry {
    margin: 0 0 1.7rem;
    padding-left: .9rem;
    border-left: 3px solid var(--ochre);
  }
  article.entry h3 { font-size: 1.05rem; margin: 0 0 .3rem; line-height: 1.35; }

  /* ── Byline: presenter + institution + co-authors ── */
  .byline { margin: 0 0 .55rem; }
  p.presenter {
    font-style: italic;
    margin: 0 0 .05rem;
    font-size: 1rem;
  }
  p.presenter .institution {
    font-style: normal;
    font-size: .85em;
    color: var(--terra);
    font-family: -apple-system, system-ui, sans-serif;
  }
  p.presenter .institution::before { content: " · "; color: var(--rule); }
  p.coauthors {
    font-style: italic;
    font-size: .95rem;
    color: var(--ink);
    margin: 0;
    padding-left: .75rem;
    border-left: 2px solid var(--rule);
  }

  p.abstract { margin: 0 0 .4rem; }
  p.keywords {
    font-family: -apple-system, system-ui, sans-serif;
    font-size: .78rem;
    color: var(--muted);
    margin: 0;
  }

  footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--rule);
    font-size: .78rem;
    color: var(--muted);
    font-family: -apple-system, system-ui, sans-serif;
  }
  @media (max-width: 520px) {
    .header-top { flex-direction: column; gap: .6rem; }
    .logo { height: 3rem; }
    header h1 { font-size: 1.4rem; }
  }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="header-top">
      {% if has_logo %}<img src="logo.png" class="logo" alt="{{ conf.title }}">{% endif %}
      <div class="header-text">
        <h1>{{ conf.title }}</h1>
        <p class="subtitle">{{ conf.subtitle }}</p>
        <p class="meta">
          {{ conf.dates }} · {{ conf.location }} ·
          {{ total }} Beiträge ·
          <a href="book_of_contents.pdf">PDF herunterladen</a>
        </p>
      </div>
    </div>
    <div class="triband" aria-hidden="true"></div>
  </header>

  {% if intro %}
  <section class="intro">{{ intro | safe }}</section>
  {% endif %}

  <nav class="toc">
    <strong>Inhalt</strong>
    <ol>
      {% for block in sessions %}
      <li><a href="#s{{ loop.index }}">{{ block.track }}</a> ({{ block.entries|length }})</li>
      {% endfor %}
    </ol>
  </nav>

  {% for block in sessions %}
  <section class="session" id="s{{ loop.index }}">
    <h2>{{ block.track }}</h2>
    {% for e in block.entries %}
    <article class="entry">
      <h3>{{ e.title }}</h3>
      <div class="byline">
        {% if e.authors %}
        <p class="presenter">
          {{ e.authors }}{% if e.institution %}<span class="institution">{{ e.institution }}</span>{% endif %}
        </p>
        {% endif %}
        {% if e.co_authors %}
        <p class="coauthors">{{ e.co_authors | join(" · ") }}</p>
        {% endif %}
      </div>
      {% if e.abstract %}<p class="abstract">{{ e.abstract }}</p>{% endif %}
      {% if e.keywords %}<p class="keywords">{{ e.keywords }}</p>{% endif %}
    </article>
    {% endfor %}
  </section>
  {% endfor %}

  <footer>
    Automatisch generiert am {{ generated }}.
  </footer>
</div>
</body>
</html>
