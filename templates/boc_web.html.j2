<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ conf.title }} – {{ conf.subtitle }}</title>
<style>
  :root {
    --ink:     #1A1714;
    --muted:   #6B5F52;
    --rule:    #DDD5C8;
    --terra:   #BB4B27;
    --ochre:   #C88A2A;
    --forest:  #2B5740;
    --bg:      #EDE8E0;
    --surface: #FDFAF6;
    --measure: 72rem;
    --radius:  8px;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font: 16px/1.65 Georgia, "Times New Roman", serif;
  }
  .wrap { max-width: var(--measure); margin: 0 auto; padding: 2.5rem 2rem 5rem; }

  /* ── Header ── */
  header { background: var(--surface); }
  .header-inner {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 1.6rem 2rem 1rem;
  }
  .header-top {
    display: flex;
    align-items: center;
    gap: 1.8rem;
  }
  .logo { height: 6rem; width: auto; flex-shrink: 0; }
  .header-text { flex: 1; }
  header h1 {
    font-family: -apple-system, system-ui, sans-serif;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -.02em;
    margin: 0 0 .2rem;
    color: var(--ink);
  }
  header .subtitle {
    font-family: -apple-system, system-ui, sans-serif;
    font-size: 1rem;
    color: var(--muted);
    margin: 0 0 .4rem;
  }
  header .meta {
    font-family: -apple-system, system-ui, sans-serif;
    font-size: .82rem;
    color: var(--muted);
    margin: 0;
  }
  header .meta a { color: var(--terra); text-decoration: none; }
  header .meta a:hover { text-decoration: underline; }
  .lang-switch {
    font-family: -apple-system, system-ui, sans-serif;
    font-size: .78rem;
    margin-top: .45rem;
  }
  .lang-switch a {
    color: var(--forest);
    text-decoration: none;
    border: 1.5px solid var(--forest);
    padding: .2rem .65rem;
    border-radius: 20px;
    font-weight: 500;
  }
  .lang-switch a:hover { background: var(--forest); color: #fff; }
  .triband {
    height: 5px;
    background: linear-gradient(
      90deg,
      var(--terra)  0 33.34%,
      var(--ochre)  33.34% 66.67%,
      var(--forest) 66.67% 100%
    );
  }

  /* ── Intro + TOC row ── */
  .intro-toc-row {
    display: grid;
    grid-template-columns: 5fr 8fr;
    gap: 1.5rem;
    align-items: start;
    margin-bottom: 3rem;
  }
  .intro-toc-row > nav.toc:only-child {
    grid-column: 1 / -1;
  }

  /* ── Intro block ── */
  .intro {
    padding: 1.3rem 1.6rem;
    background: #FFF7ED;
    border-left: 4px solid var(--ochre);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-size: .93rem;
    line-height: 1.7;
    box-shadow: 0 1px 4px rgba(0,0,0,.06);
  }
  .intro p:first-child { margin-top: 0; }
  .intro p:last-child  { margin-bottom: 0; }

  /* ── TOC ── */
  nav.toc {
    font-family: -apple-system, system-ui, sans-serif;
    font-size: .875rem;
  }
  nav.toc > strong {
    display: block;
    text-transform: uppercase;
    letter-spacing: .1em;
    font-size: .68rem;
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .toc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: 1rem;
  }
  .toc-section {
    background: var(--surface);
    border-radius: var(--radius);
    padding: 1.1rem 1.3rem;
    border: 1px solid var(--rule);
    box-shadow: 0 1px 3px rgba(0,0,0,.05);
  }
  a.toc-track {
    display: block;
    font-weight: 700;
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: var(--forest);
    text-decoration: none;
    margin-bottom: .6rem;
    padding-bottom: .4rem;
    border-bottom: 1px solid var(--rule);
  }
  a.toc-track:hover { color: var(--terra); }
  .toc-count { font-weight: 400; color: var(--muted); text-transform: none; letter-spacing: 0; }
  ol.toc-entries {
    margin: 0;
    padding-left: .5rem;
    border-left: 2px solid var(--rule);
    list-style: none;
  }
  ol.toc-entries li { margin-bottom: .45rem; line-height: 1.3; }
  ol.toc-entries a { color: var(--ink); text-decoration: none; font-size: .82rem; }
  ol.toc-entries a:hover { color: var(--terra); }
  .toc-byline {
    display: block;
    font-size: .74rem;
    font-style: italic;
    font-weight: 600;
    color: var(--muted);
    margin-top: .05rem;
  }

  /* ── Sessions ── */
  section.session { margin-bottom: 3rem; }
  section.session > h2 {
    font-family: -apple-system, system-ui, sans-serif;
    font-size: .7rem;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .12em;
    margin: 0 0 1.2rem;
    padding-bottom: .5rem;
    border-bottom: 1px solid var(--rule);
    display: flex;
    align-items: center;
    gap: .7rem;
  }
  section.session > h2::before {
    content: "";
    display: inline-block;
    height: 3px;
    width: 2rem;
    flex-shrink: 0;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      var(--terra)  0 33.34%,
      var(--ochre)  33.34% 66.67%,
      var(--forest) 66.67% 100%
    );
  }

  /* ── Entry cards ── */
  article.entry {
    margin: 0 0 1rem;
    padding: 1.4rem 1.8rem;
    background: var(--surface);
    border-radius: var(--radius);
    border-left: 4px solid var(--ochre);
    box-shadow: 0 1px 4px rgba(0,0,0,.06);
  }
  article.entry h3 {
    font-size: 1.05rem;
    margin: 0 0 .3rem;
    line-height: 1.35;
  }

  /* ── Byline ── */
  .byline { margin: 0 0 .6rem; }
  p.presenter {
    font-style: italic;
    font-weight: 600;
    font-size: .95rem;
    color: var(--muted);
    margin: 0;
  }
  p.presenter .institution {
    font-style: normal;
    font-weight: 400;
    font-size: .85em;
    color: var(--terra);
    font-family: -apple-system, system-ui, sans-serif;
  }
  p.presenter .institution::before { content: " · "; color: var(--rule); }

  p.abstract { margin: 0 0 .4rem; font-size: .95rem; }
  p.keywords {
    font-family: -apple-system, system-ui, sans-serif;
    font-size: .74rem;
    color: var(--muted);
    margin: 0;
  }

  footer {
    margin-top: 3.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--rule);
    font-size: .76rem;
    color: var(--muted);
    font-family: -apple-system, system-ui, sans-serif;
  }

  @media (max-width: 640px) {
    .wrap { padding: 1.5rem 1.1rem 4rem; }
    .header-inner { padding: 1.1rem 1.1rem .8rem; }
    .header-top { flex-direction: column; align-items: flex-start; gap: .7rem; }
    .logo { height: 4rem; }
    header h1 { font-size: 1.5rem; }
    .intro-toc-row { grid-template-columns: 1fr; }
    .toc-grid { grid-template-columns: 1fr; }
    article.entry { padding: 1.1rem 1.2rem; }
  }
</style>
</head>
<body>
<header>
  <div class="header-inner">
    <div class="header-top">
      {% if has_logo %}<img src="logo.png" class="logo" alt="{{ conf.title }}">{% endif %}
      <div class="header-text">
        <h1>{{ conf.title }}</h1>
        <p class="subtitle">{{ conf.subtitle }}</p>
        <p class="meta">
          {{ conf.dates }} · {{ conf.location }} ·
          {{ total }} {{ t.contributions }} ·
          <a href="{{ t.pdf_file }}">{{ t.download_pdf }}</a>
        </p>
        <p class="lang-switch"><a href="{{ t.alt_page }}" hreflang="{{ t.lang_attr == 'de' and 'en' or 'de' }}">{{ t.alt_label }}</a></p>
      </div>
    </div>
  </div>
  <div class="triband" aria-hidden="true"></div>
</header>
<div class="wrap">
  <div class="intro-toc-row">
    {% if intro %}
    <section class="intro">{{ intro | safe }}</section>
    {% endif %}
    <nav class="toc">
    <strong>{{ t.contents }}</strong>
    <div class="toc-grid">
      {% for block in sessions %}
      {% set si = loop.index %}
      <div class="toc-section">
        <a class="toc-track" href="#s{{ si }}">{{ t.tracks.get(block.track, block.track) }} <span class="toc-count">({{ block.entries|length }})</span></a>
        <ol class="toc-entries">
          {% for e in block.entries %}
          <li>
            <a href="#e{{ si }}-{{ loop.index }}">{{ e.title }}</a>
            <span class="toc-byline">{{ e.authors }}{% if e.co_authors %}, {{ e.co_authors | join(", ") }}{% endif %}</span>
          </li>
          {% endfor %}
        </ol>
      </div>
      {% endfor %}
    </div>
    </nav>
  </div>

  {% for block in sessions %}
  {% set si = loop.index %}
  <section class="session" id="s{{ si }}">
    <h2>{{ t.tracks.get(block.track, block.track) }}</h2>
    {% for e in block.entries %}
    <article class="entry" id="e{{ si }}-{{ loop.index }}">
      <h3>{{ e.title }}</h3>
      <div class="byline">
        {% if e.authors %}
        <p class="presenter">
          {{ e.authors }}{% if e.co_authors %}, {{ e.co_authors | join(", ") }}{% endif %}{% if e.institution %}<span class="institution">{{ e.institution }}</span>{% endif %}
        </p>
        {% endif %}
      </div>
      {% if e.abstract %}<p class="abstract">{{ e.abstract }}</p>{% endif %}
      {% if e.keywords %}<p class="keywords">{{ e.keywords }}</p>{% endif %}
    </article>
    {% endfor %}
  </section>
  {% endfor %}

  <footer>
    {{ t.generated }} {{ generated }}.
  </footer>
</div>
</body>
</html>
